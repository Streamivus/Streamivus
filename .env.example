# Optional integrations. Leave blank to disable.

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX
REACT_APP_GA_ID=

# Microsoft Clarity project ID
REACT_APP_CLARITY_ID=

# Crisp live chat website ID (https://crisp.chat)
REACT_APP_CRISP_ID=

# Cal.com embed URL, e.g. https://cal.com/your-username/30min?embed=true
REACT_APP_CAL_LINK=

# EmailJS (contact form, discuss project, careers — browser SDK)
# Dashboard: https://dashboard.emailjs.com
# Required: add your domains under Account → Security → Domains
#   - streamivus.com
#   - www.streamivus.com
#   - localhost (for local dev)
REACT_APP_EMAILJS_SERVICE_ID=service_h4gtndg
REACT_APP_EMAILJS_TEMPLATE_ID=template_a9tvs7a
REACT_APP_EMAILJS_PUBLIC_KEY=lXiCUDOtu8_WY_Zw4

# Newsletter subscribe API (Vercel serverless — used in production)
# Same IDs as above; private key from EmailJS → Account → API Keys
EMAILJS_SERVICE_ID=service_h4gtndg
EMAILJS_TEMPLATE_ID=template_a9tvs7a
EMAILJS_PUBLIC_KEY=lXiCUDOtu8_WY_Zw4
EMAILJS_PRIVATE_KEY=your_private_key_from_emailjs_dashboard
